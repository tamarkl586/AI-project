{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Yarp.ReverseProxy": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:HH:mm:ss} [{Level:u3}] {CorrelationId} {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://seq"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://localhost:4200",
      "http://127.0.0.1:4200",
      "https://127.0.0.1:4200",
      "http://localhost:8080",
      "https://localhost:8080"
    ]
  },
  "Jwt": {
    "Key": "__SET_BY_ENV__",
    "Issuer": "IdentityService",
    "Audience": "IdentityServiceUsers"
  },
  "ReverseProxy": {
    "Routes": {
      "identity-auth": {
        "ClusterId": "identity-service",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/api/auth/{**catchAll}"
        }
      },
      "catalog-gifts": {
        "ClusterId": "catalog-service",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/api/gift/{**catchAll}"
        }
      },
      "catalog-categories": {
        "ClusterId": "catalog-service",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/api/category/{**catchAll}"
        }
      },
      "catalog-donors": {
        "ClusterId": "catalog-service",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/api/donor/{**catchAll}"
        }
      },
      "ticketing-cart": {
        "ClusterId": "ticketing-service",
        "AuthorizationPolicy": "RequireAuth",
        "Match": {
          "Path": "/api/cart/{**catchAll}"
        }
      },
      "draw-reports": {
        "ClusterId": "draw-report-service",
        "AuthorizationPolicy": "RequireAuth",
        "Match": {
          "Path": "/api/reports/{**catchAll}"
        }
      },
      "web-bff": {
        "ClusterId": "web-bff",
        "AuthorizationPolicy": "RequireAuth",
        "Match": {
          "Path": "/api/web/{**catchAll}"
        }
      },
      "frontend-spa": {
        "ClusterId": "frontend",
        "AuthorizationPolicy": "Anonymous",
        "Order": 100,
        "Match": {
          "Path": "/{**catchAll}"
        }
      }
    },
    "Clusters": {
      "identity-service": {
        "Destinations": {
          "identity-service": {
            "Address": "http://identityservice:8080/"
          }
        }
      },
      "catalog-service": {
        "Destinations": {
          "catalog-service-a": {
            "Address": "http://catalogservice:8080/"
          }
        }
      },
      "ticketing-service": {
        "Destinations": {
          "ticketing-service": {
            "Address": "http://ticketingservice:8080/"
          }
        }
      },
      "draw-report-service": {
        "Destinations": {
          "draw-report-service": {
            "Address": "http://drawreportservice:8080/"
          }
        }
      },
      "web-bff": {
        "Destinations": {
          "web-bff": {
            "Address": "http://webbff:8080/"
          }
        }
      },
      "frontend": {
        "Destinations": {
          "frontend": {
            "Address": "http://frontend:80/"
          }
        }
      }
    }
  }
}
