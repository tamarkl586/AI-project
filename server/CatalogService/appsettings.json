{
  "Serilog": {
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Month",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      { "Name": "Console" }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MongoDB_ConnectionString": "mongodb://localhost:27017",
  "MongoDB_DatabaseName": "catalogDb",
  "Redis_ConnectionString": "localhost:6379",
  "Jwt": {
    "Key": "THIS_IS_A_SUPER_SECRET_KEY_WITH_32_CHARS",
    "Issuer": "IdentityService",
    "Audience": "IdentityServiceUsers"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://localhost:4200",
      "http://127.0.0.1:4200",
      "https://127.0.0.1:4200"
    ]
  }
}
